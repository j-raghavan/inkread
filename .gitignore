# ───────────────────────────────────────────────────────────────
# Local / private — never commit
# ───────────────────────────────────────────────────────────────
# Design docs & ADRs live locally only (reference the private research).
spec/

# Claude Code / Ruflo working config (per-machine, not project source).
CLAUDE*
.claude/
.claude-flow/
.mcp*

# Reverse-engineering reference material is NEVER committed (clean-room,
# 3rd-party copyright). Kept out of the public repo defensively.
neoreader/
supernote/
*.apk
*.so
# Note: jniLibs/*.so are NOT committed — libreader.so is built by cargo-ndk and
# libpdfium.so is download-staged + sha256-verified by buildApk.sh (stage_pdfium).
# So all *.so stay ignored; the build reproduces them. (An earlier
# "!**/jniLibs/**" negation here was a no-op — an inline '#comment' is part of the
# pattern, not a comment — and is intentionally removed.)

# ───────────────────────────────────────────────────────────────
# Rust
# ───────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
*.pdb
# (this is an app, not a library → Cargo.lock IS committed)

# ───────────────────────────────────────────────────────────────
# Android / Gradle / Kotlin
# ───────────────────────────────────────────────────────────────
.gradle/
build/
app/build/
local.properties
*.iml
.idea/
.cxx/
.kotlin/
captures/

# Signing keys — NEVER commit (debug.keystore is fine to keep)
*.keystore
*.jks
!debug.keystore
keystore.properties

# Build outputs
*.aab
outputs/

